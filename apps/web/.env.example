NEXT_PUBLIC_SITE_URL=https://pluto.hk
NEXT_PUBLIC_DEFAULT_LOCALE=zh-CN
PUBLICATION_TIMEZONE=Asia/Shanghai
PUBLICATION_HOUR=5
PUBLICATION_MINUTE=0

STUDIO_PASSWORD=
STUDIO_SESSION_SECRET=
GITHUB_STUDIO_TOKEN=
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=vilesaint-posters-1258992379
COS_REGION=ap-hongkong
NEXT_PUBLIC_COS_BASE_URL=https://vilesaint-posters-1258992379.cos-website.ap-hongkong.myqcloud.com

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Preferred server-side Supabase keys. Preview defaults to JSON and should not
# contain the Production secret. Production uses these only for shadow compare
# while CONTENT_REPOSITORY remains json.
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=
CONTENT_REPOSITORY=json
SUPABASE_PRIMARY_READS_ENABLED=false
JSON_READ_FALLBACK_ENABLED=true
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_ENV=local
# Phase 4B safety switch. Default false means Studio keeps GitHub JSON as the
# only write path. Set true only after migrations and closed-state deployment
# checks pass. This is server-only; never use NEXT_PUBLIC_.
STUDIO_SHADOW_WRITE_ENABLED=false
# Set to true only in Vercel Production Phase 4A shadow reads.
SHADOW_COMPARE_ENABLED=false
SHADOW_COMPARE_SECRET=
# Optional protected read-only observer for recent Publish Run status.
PUBLISH_RUN_STATUS_SECRET=
# Optional protected read-only observer for Supabase primary read health.
READ_HEALTH_STATUS_SECRET=

OPENAI_API_KEY=
RESEARCH_TEXT_MODEL=gpt-5.4-mini
TRANSLATION_MODEL=gpt-5.4-mini
POSTER_IMAGE_PROVIDER=openai
POSTER_IMAGE_MODEL=gpt-image-2
POSTER_IMAGE_QUALITY=high
POSTER_IMAGE_SIZE=1920x3840
POSTER_IMAGE_FORMAT=png

CRON_SECRET=
ISSUE_CRON_UTC=0 21 * * *
AUTO_GENERATE_POSTERS=false
AUTO_PUBLISH=true
MAX_IMAGE_GENERATIONS_PER_DAY=18
