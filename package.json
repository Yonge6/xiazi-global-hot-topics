{
  "name": "xiazi-global-hot-topics",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.8",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "test:e2e:staging": "npm run test:e2e:staging -w @xiazi/web",
    "content:import": "tsx scripts/import-content-to-supabase.ts",
    "content:verify": "tsx scripts/verify-supabase-content.ts",
    "content:compare": "tsx scripts/compare-content-sources.ts",
    "audit:config": "turbo audit:config",
    "check": "turbo check",
    "web:dev": "npm run dev -w @xiazi/web",
    "posters:default": "npm run posters:default -w @xiazi/web"
  },
  "devDependencies": {
    "supabase": "^2.107.0",
    "tsx": "^4.22.4",
    "turbo": "^2.6.1"
  },
  "overrides": {
    "postcss": "^8.5.15"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2"
  }
}
